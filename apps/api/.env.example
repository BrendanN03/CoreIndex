# Copy to ".env" in this folder (apps/api). CoreIndex loads it on startup (and dev-stack passes it to uvicorn).
#
# Local dev: repo-root `npm run dev` runs the API on port 8010 and Vite on 5173 (see scripts/dev-stack.mjs).
# Keep 8000 free for SSH port-forward to the GPU machine’s remote_factor_server.
#
# --- GPU / CADO server (remote_factor_server) ---
# On the GPU machine, from e.g. /home/coreindex/cado_improved:
#   uvicorn remote_factor_server:app --host 0.0.0.0 --port 8000
#
# If CoreIndex API also uses local port 8000, forward the GPU server to a different local port, e.g. 9000:
#   ssh -N -L 9000:127.0.0.1:8000 YOUR_USER@GPU_SERVER_HOST
#   FACTORING_REMOTE_HTTP_URL=http://127.0.0.1:9000
#
# If nothing else uses 8000 locally:
FACTORING_REMOTE_HTTP_URL=http://127.0.0.1:8000

# Optional: only used for labels / default SSH hint in the UI
# Human-readable label in API responses (e.g. hostname of the GPU box).
FACTORING_SSH_HOST=qubit0

# If the remote app mounts factor elsewhere:
# FACTORING_REMOTE_FACTOR_PATH=/factor

# Timeouts for POST /factor (connect, read). Read can be long for CADO.
FACTORING_HTTP_CONNECT_TIMEOUT_SECONDS=15
FACTORING_HTTP_READ_TIMEOUT_SECONDS=86400

# Optional: override the whole setup paragraph in the web UI
# FACTORING_SETUP_HINT=Your team-specific instructions here.

# One-click demo: set to true to require human provider nominations only (default: sim sellers count).
# DEMO_REQUIRE_REAL_PROVIDERS=true

# Optional: on API startup, set voucher *wallet* balance to this many NGH for every known product key
# (persisted keys + demo key + sim catalog + all GPU-template region/SLA/tier × hours 0–23).
# Leave unset to keep normal balances. DEMO_VOUCHER_FILL_TEMPLATE_HOURS=false limits to smaller key set.
# DEMO_VOUCHER_WALLET_NGH=1000000
# DEMO_VOUCHER_FILL_TEMPLATE_HOURS=true
