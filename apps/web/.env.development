# Vite dev server: proxy target if you use `VITE_API_BASE_URL=/coreindex-api`.
# By default the web app calls the API directly at http://127.0.0.1:8010 (see src/lib/api.ts) to avoid proxy timeouts.
VITE_API_PROXY_TARGET=http://127.0.0.1:8010
# Optional: override API port when using direct mode (default 8010).
# VITE_COREINDEX_API_PORT=8010
# Optional: force same-origin proxy instead of direct API (can wedge if proxy misconfigured).
# VITE_API_BASE_URL=/coreindex-api
